<%- include('partials/header') %>

<main class="min-h-screen pt-20 pb-12 px-4">
  <div class="max-w-3xl mx-auto">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <a href="/dashboard" class="text-sm text-gray-500 hover:text-gray-300 transition-colors flex items-center gap-1 mb-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Back to Dashboard
        </a>
        <h1 class="font-display text-2xl font-bold text-white" id="quiz-title">Loading Quiz...</h1>
      </div>
      <div id="quiz-difficulty" class="glass-card px-3 py-1.5 text-xs font-semibold text-brand-400"></div>
    </div>

    <!-- Progress Bar -->
    <div class="w-full h-1.5 bg-white/5 rounded-full mb-8 overflow-hidden">
      <div id="quiz-progress" class="h-full bg-gradient-to-r from-brand-500 to-accent-500 rounded-full transition-all duration-500" style="width: 0%"></div>
    </div>

    <!-- Quiz Container -->
    <div id="quiz-container" class="space-y-6">
      <div class="glass-card p-8 text-center">
        <div class="w-10 h-10 border-2 border-brand-500 border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
        <p class="text-gray-400">Generating your personalized quiz...</p>
        <p class="text-xs text-gray-600 mt-2">AI is analyzing your past performance</p>
      </div>
    </div>

    <!-- Results Container (hidden initially) -->
    <div id="results-container" class="hidden animate-slide-up">
      <div class="glass-card p-8 text-center mb-6">
        <h2 class="font-display text-2xl font-bold text-white mb-2">Quiz Complete!</h2>
        <div class="flex items-center justify-center gap-4 my-6">
          <div class="text-center">
            <span id="result-score" class="font-display text-5xl font-bold bg-gradient-to-r from-brand-400 to-accent-400 bg-clip-text text-transparent">0</span>
            <span class="font-display text-2xl text-gray-500">/<span id="result-total">5</span></span>
          </div>
        </div>
        <p id="result-message" class="text-gray-400 mb-4"></p>
        <div class="flex items-center justify-center gap-2">
          <span class="text-sm text-gray-500">New Mastery:</span>
          <span id="result-mastery" class="text-sm font-bold text-brand-400">0%</span>
        </div>
      </div>

      <div id="results-detail" class="space-y-4"></div>

      <div class="flex gap-3 mt-6">
        <a href="/dashboard" class="btn-secondary flex-1 text-center text-sm">Back to Dashboard</a>
        <button onclick="location.reload()" class="btn-primary flex-1 text-sm">Retry Quiz</button>
      </div>
    </div>
  </div>
</main>

<script>
  const urlParams = new URLSearchParams(window.location.search);
  const subject = urlParams.get('subject') || 'General';
  const topic = urlParams.get('topic') || 'General';
  let questions = [];
  let currentQ = 0;
  let answers = [];

  document.getElementById('quiz-title').textContent = `${topic} — ${subject}`;

  // Generate quiz on load
  (async () => {
    try {
      const res = await fetch('/quiz/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ topic, subject }),
      });
      const data = await res.json();
      questions = data.questions || [];
      
      if (data.difficultyLevel) {
        document.getElementById('quiz-difficulty').textContent = `Level ${data.difficultyLevel}/5`;
      }

      if (questions.length > 0) {
        showQuestion(0);
      } else {
        document.getElementById('quiz-container').innerHTML =
          '<div class="glass-card p-8 text-center"><p class="text-red-400">No questions generated. Try a different topic.</p></div>';
      }
    } catch (e) {
      document.getElementById('quiz-container').innerHTML =
        '<div class="glass-card p-8 text-center"><p class="text-red-400">Failed to generate quiz. Please try again.</p></div>';
    }
  })();

  function showQuestion(index) {
    currentQ = index;
    const q = questions[index];
    const progress = ((index) / questions.length) * 100;
    document.getElementById('quiz-progress').style.width = progress + '%';

    const container = document.getElementById('quiz-container');
    container.innerHTML = `
      <div class="glass-card p-8 animate-fade-in">
        <div class="flex items-center justify-between mb-4">
          <span class="text-xs text-gray-500">Question ${index + 1} of ${questions.length}</span>
          ${q.difficulty ? `<span class="badge bg-brand-500/20 text-brand-400 border border-brand-500/30">Difficulty: ${q.difficulty}</span>` : ''}
        </div>
        <h3 class="text-lg font-semibold text-white mb-6 leading-relaxed">${q.question}</h3>
        <div class="space-y-3" id="options-container">
          ${q.options.map((opt, i) => `
            <button onclick="selectAnswer(${i})" id="opt-${i}"
              class="w-full text-left px-5 py-4 bg-white/5 border border-white/10 rounded-xl text-gray-300 text-sm
                     hover:bg-white/10 hover:border-brand-400/30 transition-all duration-200 group">
              <span class="inline-flex items-center gap-3">
                <span class="w-7 h-7 rounded-lg bg-white/5 flex items-center justify-center text-xs font-bold text-gray-400 group-hover:bg-brand-500/20 group-hover:text-brand-400 transition-all">
                  ${String.fromCharCode(65 + i)}
                </span>
                ${opt.replace(/^[A-D]\)\s*/, '')}
              </span>
            </button>
          `).join('')}
        </div>
      </div>
    `;
  }

  function selectAnswer(optIndex) {
    answers[currentQ] = optIndex;
    const correct = questions[currentQ].correct;

    // Highlight correct/wrong
    const opts = document.getElementById('options-container').children;
    for (let i = 0; i < opts.length; i++) {
      opts[i].disabled = true;
      opts[i].classList.remove('hover:bg-white/10', 'hover:border-brand-400/30');
      if (i === correct) {
        opts[i].classList.add('bg-emerald-500/10', 'border-emerald-500/40', 'text-emerald-400');
      } else if (i === optIndex && i !== correct) {
        opts[i].classList.add('bg-red-500/10', 'border-red-500/40', 'text-red-400');
      }
    }

    // Show explanation
    const card = document.querySelector('#quiz-container .glass-card');
    const explanation = document.createElement('div');
    explanation.className = 'mt-4 p-4 bg-white/5 rounded-xl border border-white/10 animate-fade-in';
    explanation.innerHTML = `<p class="text-xs text-gray-400 mb-1 font-semibold">Explanation:</p><p class="text-sm text-gray-300">${questions[currentQ].explanation || 'No explanation available.'}</p>`;
    card.appendChild(explanation);

    // Next button
    const nextBtn = document.createElement('button');
    nextBtn.className = 'btn-primary w-full text-sm mt-4 animate-fade-in';
    nextBtn.textContent = currentQ < questions.length - 1 ? 'Next Question →' : 'See Results';
    nextBtn.onclick = currentQ < questions.length - 1
      ? () => showQuestion(currentQ + 1)
      : submitQuiz;
    card.appendChild(nextBtn);
  }

  async function submitQuiz() {
    document.getElementById('quiz-progress').style.width = '100%';

    try {
      const res = await fetch('/quiz/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ topic, subject, answers, questions }),
      });
      const data = await res.json();

      document.getElementById('quiz-container').classList.add('hidden');
      document.getElementById('results-container').classList.remove('hidden');
      document.getElementById('result-score').textContent = data.score;
      document.getElementById('result-total').textContent = data.total;
      document.getElementById('result-mastery').textContent = data.mastery + '%';

      let msg = '';
      const pct = (data.score / data.total) * 100;
      if (pct === 100) msg = '🎯 Perfect! You\'ve mastered this topic!';
      else if (pct >= 80) msg = '🔥 Excellent performance!';
      else if (pct >= 60) msg = '👍 Good job! Keep practicing.';
      else if (pct >= 40) msg = '📚 Needs improvement. Review the topic.';
      else msg = '💪 Don\'t give up! Try the hints in Study Suite.';
      document.getElementById('result-message').textContent = msg;

      // Show detailed results
      const detail = document.getElementById('results-detail');
      detail.innerHTML = data.results.map((r, i) => `
        <div class="glass-card p-4 ${r.correct ? 'border-emerald-500/20' : 'border-red-500/20'}">
          <div class="flex items-start gap-3">
            <span class="mt-1 ${r.correct ? 'text-emerald-400' : 'text-red-400'}">${r.correct ? '✓' : '✗'}</span>
            <div class="flex-1">
              <p class="text-sm text-white mb-1">${r.question}</p>
              ${!r.correct ? `<p class="text-xs text-red-400">Your answer: ${r.userAnswer}</p>` : ''}
              <p class="text-xs text-emerald-400">Correct: ${r.correctAnswer}</p>
              <p class="text-xs text-gray-500 mt-1">${r.explanation || ''}</p>
            </div>
          </div>
        </div>
      `).join('');
    } catch (e) {
      alert('Failed to submit quiz. Please try again.');
    }
  }
</script>

<%- include('partials/footer') %>
