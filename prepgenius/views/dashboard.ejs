<%- include('partials/header') %>

<main class="min-h-screen pt-20 pb-12 px-4">
  <div class="max-w-7xl mx-auto">
    <!-- Welcome Header -->
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-8 gap-4">
      <div>
        <h1 class="font-display text-3xl font-bold text-white mb-1">
          Welcome back, <span class="bg-gradient-to-r from-brand-400 to-accent-400 bg-clip-text text-transparent"><%= user.username %></span>
        </h1>
        <p class="text-gray-400">Your <span class="text-brand-400 font-semibold"><%= exam %></span> Command Center</p>
      </div>
      <div class="flex items-center gap-3">
        <div class="glass-card px-4 py-2 flex items-center gap-2">
          <svg class="w-4 h-4 text-accent-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <span class="text-sm text-gray-300 flex items-center gap-2">Target:
            <select id="target-year-select" class="bg-gray-800 text-white font-bold outline-none cursor-pointer hover:bg-gray-700 transition-colors rounded-lg px-2 py-1 border border-gray-700 focus:border-brand-500" onchange="updateTargetYear(this.value); updateCountdown(this.value);">
              <% const cYear = new Date().getFullYear(); %>
              <% for(let y = cYear; y <= cYear + 5; y++) { %>
                <option value="<%= y %>" class="bg-gray-900 text-white" <%= y == targetYear ? 'selected' : '' %>><%= y %></option>
              <% } %>
            </select>
          </span>
          <div id="exam-countdown" class="ml-2 transition-all"></div>
        </div>
      </div>
    </div>

    <div class="grid lg:grid-cols-3 gap-6">
      <!-- LEFT: Mastery Circles -->
      <div class="lg:col-span-2">
        <div class="glass-card p-6 mb-6">
          <h2 class="font-display text-lg font-bold text-white mb-6 flex items-center gap-2">
            <svg class="w-5 h-5 text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
            Syllabus Mastery
          </h2>
          <div class="grid grid-cols-2 md:grid-cols-<%= subjects.length %> gap-6">
            <% mastery.forEach((item, index) => { %>
            <% const colors = ['from-blue-500 to-cyan-500', 'from-emerald-500 to-teal-500', 'from-violet-500 to-purple-500']; %>
            <% const trackColors = ['stroke-blue-500/20', 'stroke-emerald-500/20', 'stroke-violet-500/20']; %>
            <% const ringColors = ['stroke-blue-500', 'stroke-emerald-500', 'stroke-violet-500']; %>
            <div class="flex flex-col items-center">
              <div class="mastery-circle w-32 h-32 mb-3">
                <svg class="w-32 h-32 -rotate-90" viewBox="0 0 120 120">
                  <circle cx="60" cy="60" r="52" fill="none" stroke-width="8" class="<%= trackColors[index % 3] %>"/>
                  <circle cx="60" cy="60" r="52" fill="none" stroke-width="8"
                    class="mastery-ring <%= ringColors[index % 3] %>"
                    stroke-linecap="round"
                    stroke-dasharray="<%= 2 * Math.PI * 52 %>"
                    stroke-dashoffset="<%= 2 * Math.PI * 52 * (1 - item.mastery / 100) %>"
                    data-target="<%= item.mastery %>"/>
                </svg>
                <div class="absolute inset-0 flex flex-col items-center justify-center">
                  <span class="font-display text-2xl font-bold text-white"><%= item.mastery %>%</span>
                  <span class="text-[10px] text-gray-500 uppercase tracking-wider">mastery</span>
                </div>
              </div>
              <h3 class="text-sm font-semibold text-white"><%= item.subject %></h3>
              <p class="text-xs text-gray-500"><%= item.topicCount %> topics tracked</p>
            </div>
            <% }); %>
          </div>
        </div>

        <!-- Action Buttons Grid -->
        <div class="grid grid-cols-2 gap-4">
          <!-- Quick Quiz -->
          <button onclick="openQuizModal()" id="quick-quiz-btn" class="glass-card-hover p-5 text-left group">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center mb-3 group-hover:shadow-lg group-hover:shadow-brand-500/20 transition-all">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h3 class="text-sm font-bold text-white mb-1">Quick Quiz</h3>
            <p class="text-xs text-gray-500">Test your knowledge</p>
          </button>

          <!-- Topic Strength -->
          <button onclick="openTopicStrength()" id="topic-strength-btn" class="glass-card-hover p-5 text-left group">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-accent-600 to-accent-500 flex items-center justify-center mb-3 group-hover:shadow-lg group-hover:shadow-accent-500/20 transition-all">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <h3 class="text-sm font-bold text-white mb-1">Topic Strength</h3>
            <p class="text-xs text-gray-500">Weak / Good / Mastered</p>
          </button>

          <!-- Study Planner -->
          <a href="/planner" id="study-planner-link" class="glass-card-hover p-5 text-left group block">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center mb-3 group-hover:shadow-lg group-hover:shadow-emerald-500/20 transition-all">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <h3 class="text-sm font-bold text-white mb-1">📅 Study Planner</h3>
            <p class="text-xs text-gray-500">AI daily study schedule</p>
          </a>

          <!-- YouTube Notes -->
          <a href="/study" onclick="sessionStorage.setItem('openTab','youtube')" id="youtube-notes-link" class="glass-card-hover p-5 text-left group block">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-red-500 to-rose-600 flex items-center justify-center mb-3 group-hover:shadow-lg group-hover:shadow-red-500/20 transition-all">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h3 class="text-sm font-bold text-white mb-1">🎬 YouTube Notes</h3>
            <p class="text-xs text-gray-500">Video → AI study notes</p>
          </a>

          <!-- Study Suite -->
          <a href="/study" id="study-suite-link" class="glass-card-hover p-5 text-left group block col-span-2 flex items-center gap-4">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-violet-500 to-purple-600 flex items-center justify-center flex-shrink-0 group-hover:shadow-lg group-hover:shadow-violet-500/20 transition-all">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
            </div>
            <div>
              <h3 class="text-base font-bold text-white mb-1">AI Study Suite</h3>
              <p class="text-sm text-gray-500">Doubt Solver, Document Summaries & Notes</p>
            </div>
          </a>
        </div>
      </div>

      <!-- RIGHT: Status Panel -->
      <div class="space-y-6">
        <!-- Predictive Rank -->
        <div class="glass-card p-6">
          <h2 class="font-display text-lg font-bold text-white mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
            </svg>
            Predictive Rank
          </h2>
          <% if (predictiveRank) { %>
          <div class="text-center py-4">
            <span class="font-display text-5xl font-bold bg-gradient-to-r from-amber-400 to-orange-400 bg-clip-text text-transparent">
              #<%= predictiveRank.toLocaleString() %>
            </span>
            <p class="text-sm text-gray-500 mt-2">Based on quiz performance</p>
          </div>
          <% } else { %>
          <div class="text-center py-6">
            <div class="w-16 h-16 rounded-full bg-white/5 flex items-center justify-center mx-auto mb-3">
              <svg class="w-8 h-8 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
              </svg>
            </div>
            <p class="text-sm text-gray-500">Take quizzes to see your predicted rank</p>
          </div>
          <% } %>
        </div>

        <!-- Quick Stats -->
        <div class="glass-card p-6">
          <h2 class="font-display text-lg font-bold text-white mb-4">Quick Stats</h2>
          <div class="space-y-3">
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-400">Overall Mastery</span>
              <span class="text-sm font-bold text-white">
                <%= Math.round(mastery.reduce((s,m) => s + m.mastery, 0) / (mastery.length || 1)) %>%
              </span>
            </div>
            <div class="w-full h-2 bg-white/5 rounded-full overflow-hidden">
              <div class="h-full bg-gradient-to-r from-brand-500 to-accent-500 rounded-full transition-all duration-1000"
                style="width: <%= Math.round(mastery.reduce((s,m) => s + m.mastery, 0) / (mastery.length || 1)) %>%"></div>
            </div>
            <div class="flex items-center justify-between pt-2">
              <span class="text-sm text-gray-400">Due Revisions</span>
              <span class="text-sm font-bold <%= dueRevisions.length > 0 ? 'text-amber-400' : 'text-accent-400' %>">
                <%= dueRevisions.length %>
              </span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-gray-400">Topics Tracked</span>
              <span class="text-sm font-bold text-white"><%= mastery.reduce((s,m) => s + m.topicCount, 0) %></span>
            </div>
          </div>
        </div>

        <!-- Due Revisions List -->
        <% if (dueRevisions.length > 0) { %>
        <div class="glass-card p-6">
          <h2 class="font-display text-sm font-bold text-amber-400 mb-3 flex items-center gap-2">
            <div class="w-2 h-2 bg-amber-400 rounded-full animate-pulse"></div>
            Due for Review
          </h2>
          <div class="space-y-2 max-h-48 overflow-y-auto">
            <% dueRevisions.forEach(rev => { %>
            <div class="flex items-center justify-between py-2 border-b border-white/5 last:border-0">
              <span class="text-sm text-gray-300"><%= rev.topic %></span>
              <span class="text-xs text-gray-500"><%= rev.subject %></span>
            </div>
            <% }); %>
          </div>
        </div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Quick Quiz Modal -->
  <div id="quiz-modal" class="modal-backdrop">
    <div class="modal-content glass-card p-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-display text-xl font-bold text-white">Quick Quiz</h2>
        <button onclick="closeQuizModal()" class="text-gray-400 hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <form id="quiz-start-form" class="space-y-4">
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">Subject</label>
          <select id="quiz-subject" class="input-field" required>
            <% subjects.forEach(s => { %>
            <option value="<%= s %>" class="bg-gray-900 text-white"><%= s %></option>
            <% }); %>
          </select>
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1.5">Topic</label>
          <input type="text" id="quiz-topic" placeholder="e.g., Newton's Laws, Organic Reactions..." class="input-field" required>
        </div>
        <div class="grid grid-cols-2 gap-3 pt-2">
          <button type="submit" id="generate-quiz-btn" class="btn-primary text-sm">
            <span class="flex items-center justify-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
              Generate Quiz
            </span>
          </button>
          <label class="btn-secondary text-sm cursor-pointer">
            <span class="flex items-center justify-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/>
              </svg>
              Upload Book
            </span>
            <input type="file" accept=".pdf" class="hidden" id="quiz-upload-book">
          </label>
        </div>
      </form>
    </div>
  </div>

  <!-- Topic Strength Modal -->
  <div id="topic-modal" class="modal-backdrop">
    <div class="modal-content glass-card p-8 max-h-[80vh] overflow-y-auto">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-display text-xl font-bold text-white">Topic Strength</h2>
        <button onclick="closeTopicStrength()" class="text-gray-400 hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div id="topic-strength-content">
        <div class="text-center py-8 text-gray-500">
          <div class="w-8 h-8 border-2 border-brand-500 border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
          Loading...
        </div>
      </div>
    </div>
  </div>
</main>

<script>
  const CURRENT_EXAM = "<%= typeof exam !== 'undefined' ? exam.toUpperCase() : 'GENERAL' %>";

  async function updateCountdown(yearStr) {
    const container = document.getElementById('exam-countdown');
    container.innerHTML = `<div class="w-1.5 h-1.5 bg-brand-400 rounded-full animate-pulse"></div>
                           <span class="text-xs font-bold text-brand-400 tracking-wide">AI Checking Dates...</span>`;
    container.className = "ml-2 px-3 py-1 bg-brand-500/10 border border-brand-500/20 rounded-full flex items-center gap-2 shadow-lg shadow-brand-500/5";

    const year = parseInt(yearStr);
    let examDate;
    
    try {
      const res = await fetch(`/api/exam-date?exam=${CURRENT_EXAM}&year=${year}`);
      const data = await res.json();
      if (data.date) {
        const parts = data.date.split('-');
        examDate = new Date(parts[0], parseInt(parts[1]) - 1, parts[2]);
      }
    } catch (e) { console.error('AI Date Fetch Error:', e); }

    // Approximate typical exam dates in India if AI says "NO"
    if (!examDate) {
      if (CURRENT_EXAM.includes('JEE')) {
        examDate = new Date(year, 3, 10); // April 10
      } else if (CURRENT_EXAM.includes('NEET')) {
        examDate = new Date(year, 4, 5); // May 5
      } else if (CURRENT_EXAM.includes('UPSC')) {
        examDate = new Date(year, 4, 26); // May 26
      } else {
        examDate = new Date(year, 5, 1); // Generic June 1
      }
    }

    const today = new Date();
    const diffTime = examDate - today;
    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
    
    if (diffDays < 0) {
      container.innerHTML = `<span class="text-xs font-bold text-gray-400">Exam Passed</span>`;
      container.className = "ml-2 px-3 py-1 bg-gray-500/10 border border-gray-500/20 rounded-full";
    } else {
      container.innerHTML = `<div class="w-1.5 h-1.5 bg-amber-400 rounded-full animate-pulse"></div>
                             <span class="text-xs font-bold text-amber-400 tracking-wide">${diffDays} Days Left</span>`;
      container.className = "ml-2 px-3 py-1 bg-amber-500/10 border border-amber-500/20 rounded-full flex items-center gap-2 shadow-lg shadow-amber-500/5";
    }
  }

  // Initialize countdown immediately
  const selectNode = document.getElementById('target-year-select');
  if (selectNode) updateCountdown(selectNode.value);

  function openQuizModal() {
    document.getElementById('quiz-modal').classList.add('active');
  }
  function closeQuizModal() {
    document.getElementById('quiz-modal').classList.remove('active');
  }
  function openTopicStrength() {
    document.getElementById('topic-modal').classList.add('active');
    fetchTopicStrength();
  }
  function closeTopicStrength() {
    document.getElementById('topic-modal').classList.remove('active');
  }

  // Fetch topic strength
  async function fetchTopicStrength() {
    try {
      const res = await fetch('/topic-strength');
      const data = await res.json();
      const container = document.getElementById('topic-strength-content');

      if (!data.weak.length && !data.good.length && !data.mastered.length) {
        container.innerHTML = '<p class="text-center text-gray-500 py-8">No topics tracked yet. Take some quizzes first!</p>';
        return;
      }

      let html = '';
      const sections = [
        { key: 'weak', label: '🔴 Weak', css: 'badge-weak' },
        { key: 'good', label: '🟡 Good', css: 'badge-good' },
        { key: 'mastered', label: '🟢 Mastered', css: 'badge-mastered' },
      ];

      sections.forEach(sec => {
        if (data[sec.key].length > 0) {
          html += `<div class="mb-4"><h3 class="text-sm font-bold text-gray-300 mb-2">${sec.label}</h3>`;
          data[sec.key].forEach(t => {
            html += `<div class="flex items-center justify-between py-2 border-b border-white/5">
              <div><span class="text-sm text-white">${t.topic}</span><span class="text-xs text-gray-500 ml-2">${t.subject}</span></div>
              <span class="${sec.css}">${t.mastery}%</span>
            </div>`;
          });
          html += '</div>';
        }
      });

      container.innerHTML = html;
    } catch (e) {
      document.getElementById('topic-strength-content').innerHTML = '<p class="text-center text-red-400">Failed to load.</p>';
    }
  }

  // Quiz form submission -> redirect to quiz page
  document.getElementById('quiz-start-form').addEventListener('submit', (e) => {
    e.preventDefault();
    const subject = document.getElementById('quiz-subject').value;
    const topic = document.getElementById('quiz-topic').value;
    if (topic.trim()) {
      window.location.href = `/quiz/page?subject=${encodeURIComponent(subject)}&topic=${encodeURIComponent(topic)}`;
    }
  });

  // Handle Book Upload for Quick Quiz
  document.getElementById('quiz-upload-book').addEventListener('change', async function() {
    if (!this.files[0]) return;
    const label = this.parentElement;
    const span = label.querySelector('span');
    const originalContent = span.innerHTML;
    span.innerHTML = '<div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div> Extracting...';
    
    const formData = new FormData();
    formData.append('file', this.files[0]);
    
    try {
      const res = await fetch('/study/upload', { method: 'POST', body: formData });
      const data = await res.json();
      if (data.error) throw new Error(data.error);
      
      const text = data.extractedText ? data.extractedText.replace(/\s+/g, ' ').trim() : data.originalName;
      document.getElementById('quiz-topic').value = 'Book Excerpt: ' + text.substring(0, 150) + '...';
    } catch (e) {
      alert('Upload failed: ' + e.message);
    } finally {
      span.innerHTML = originalContent;
      this.value = ''; // Reset input so same file can be uploaded again
    }
  });

  // Update Target Year
  async function updateTargetYear(year) {
    try {
      const res = await fetch('/update-target-year', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ year })
      });
      const data = await res.json();
      if (!data.success) throw new Error(data.error);
      
      const select = document.getElementById('target-year-select');
      select.classList.add('text-brand-400');
      setTimeout(() => select.classList.remove('text-brand-400'), 1000);
    } catch (e) {
      alert('Failed to update target year');
    }
  }

  // Close modals on backdrop click
  ['quiz-modal', 'topic-modal'].forEach(id => {
    document.getElementById(id).addEventListener('click', (e) => {
      if (e.target.classList.contains('modal-backdrop')) {
        document.getElementById(id).classList.remove('active');
      }
    });
  });
</script>

<%- include('partials/footer') %>
