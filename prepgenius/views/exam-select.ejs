<%- include('partials/header') %>

<main class="min-h-screen flex items-center justify-center px-4 pt-20 pb-12 relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/4 left-1/3 w-72 h-72 bg-brand-500/8 rounded-full blur-[100px]"></div>
    <div class="absolute bottom-1/3 right-1/4 w-64 h-64 bg-accent-500/8 rounded-full blur-[100px]"></div>
  </div>

  <div class="w-full max-w-4xl animate-slide-up">
    <div class="text-center mb-12">
      <h1 class="font-display text-4xl md:text-5xl font-bold text-white mb-4">Choose Your Exam</h1>
      <p class="text-gray-400 text-lg">Select your target examination to personalize your AI study experience</p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <!-- JEE Card -->
      <form action="/select-exam" method="POST">
        <input type="hidden" name="exam" value="JEE">
        <button type="submit" id="select-jee" class="w-full group glass-card-hover p-8 text-left cursor-pointer">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-blue-500 to-cyan-500 flex items-center justify-center mb-6 group-hover:shadow-lg group-hover:shadow-blue-500/20 transition-all">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/>
            </svg>
          </div>
          <h2 class="font-display text-2xl font-bold text-white mb-2">JEE</h2>
          <p class="text-gray-400 text-sm mb-4">Joint Entrance Examination for top engineering colleges.</p>
          <div class="flex flex-wrap gap-2">
            <span class="text-xs px-2 py-1 bg-blue-500/10 text-blue-400 rounded-md">Physics</span>
            <span class="text-xs px-2 py-1 bg-cyan-500/10 text-cyan-400 rounded-md">Chemistry</span>
            <span class="text-xs px-2 py-1 bg-indigo-500/10 text-indigo-400 rounded-md">Maths</span>
          </div>
        </button>
      </form>

      <!-- NEET Card -->
      <form action="/select-exam" method="POST">
        <input type="hidden" name="exam" value="NEET">
        <button type="submit" id="select-neet" class="w-full group glass-card-hover p-8 text-left cursor-pointer">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-emerald-500 to-teal-500 flex items-center justify-center mb-6 group-hover:shadow-lg group-hover:shadow-emerald-500/20 transition-all">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </div>
          <h2 class="font-display text-2xl font-bold text-white mb-2">NEET</h2>
          <p class="text-gray-400 text-sm mb-4">National medical entrance for MBBS & BDS admissions.</p>
          <div class="flex flex-wrap gap-2">
            <span class="text-xs px-2 py-1 bg-emerald-500/10 text-emerald-400 rounded-md">Physics</span>
            <span class="text-xs px-2 py-1 bg-teal-500/10 text-teal-400 rounded-md">Chemistry</span>
            <span class="text-xs px-2 py-1 bg-green-500/10 text-green-400 rounded-md">Biology</span>
          </div>
        </button>
      </form>

      <!-- UPSC Card -->
      <form action="/select-exam" method="POST">
        <input type="hidden" name="exam" value="UPSC">
        <button type="submit" id="select-upsc" class="w-full group glass-card-hover p-8 text-left cursor-pointer">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-amber-500 to-orange-500 flex items-center justify-center mb-6 group-hover:shadow-lg group-hover:shadow-amber-500/20 transition-all">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9"/>
            </svg>
          </div>
          <h2 class="font-display text-2xl font-bold text-white mb-2">UPSC</h2>
          <p class="text-gray-400 text-sm mb-4">Civil Services Examination for administrative roles.</p>
          <div class="flex flex-wrap gap-2">
            <span class="text-xs px-2 py-1 bg-amber-500/10 text-amber-400 rounded-md">GS</span>
            <span class="text-xs px-2 py-1 bg-orange-500/10 text-orange-400 rounded-md">CSAT</span>
            <span class="text-xs px-2 py-1 bg-yellow-500/10 text-yellow-400 rounded-md">Optional</span>
          </div>
        </button>
      </form>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
