<%- include('partials/header') %>

<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --bg:#07080f;
  --bg2:#0e0f1a;
  --bg3:#141526;
  --surface:#1a1b2e;
  --surface2:#22243a;
  --border:#2a2d4a;
  --border2:#353860;
  --text:#e8eaf6;
  --text2:#9196c4;
  --text3:#5a5f8a;
  --accent:#6c63ff;
  --accent2:#ff6584;
  --gold:#ffd166;
  --teal:#06d6a0;
  --red:#ff4757;
  --orange:#ff9f43;
  --green:#06d6a0;
  --blue:#4ecdc4;
  --font:'Space Grotesk',sans-serif;
  --mono:'JetBrains Mono',monospace;
}

html,body{height:100%;background:var(--bg);color:var(--text);font-family:var(--font);font-size:13px;overflow-x:hidden}

::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:var(--bg2)}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}

.topbar{
  background:var(--bg2);
  border-bottom:1px solid var(--border);
  height:52px;display:flex;align-items:center;
  padding:0 20px;gap:12px;
  position:sticky;top:0;z-index:200;
}
.logo{font-size:17px;font-weight:700;letter-spacing:-0.5px;color:var(--text)}
.logo em{color:var(--accent);font-style:normal}
.topbar-tabs{display:flex;gap:2px;margin-left:20px}
.ttab{
  padding:6px 14px;font-size:12px;font-weight:500;
  border-radius:6px;cursor:pointer;color:var(--text2);
  transition:all .15s;border:none;background:transparent;
}
.ttab:hover{background:var(--surface);color:var(--text)}
.ttab.active{background:var(--accent);color:white}
.topbar-right{margin-left:auto;display:flex;align-items:center;gap:10px}
.badge{font-size:10px;padding:3px 8px;border-radius:10px;font-weight:600;background:var(--surface2);color:var(--text2)}
.badge.warn{background:rgba(255,71,87,0.15);color:var(--red)}
.badge.good{background:rgba(6,214,160,0.15);color:var(--teal)}

.app{display:grid;grid-template-columns:320px 1fr;height:calc(100vh - 52px);overflow:hidden}
.sidebar{background:var(--bg2);border-right:1px solid var(--border);overflow-y:auto;display:flex;flex-direction:column}
.main-panel{overflow-y:auto;padding:20px}

.panel-head{
  padding:14px 16px 10px;
  font-size:11px;font-weight:600;letter-spacing:1px;
  color:var(--text3);text-transform:uppercase;
  border-bottom:1px solid var(--border);
}
.panel-head span{color:var(--accent);margin-left:6px;text-transform:none;letter-spacing:0;font-weight:500;font-size:10px}

.topic-item{
  padding:10px 16px;border-bottom:1px solid var(--border);
  cursor:pointer;transition:background .12s;
  display:flex;align-items:center;gap:10px;
}
.topic-item:hover{background:var(--surface)}
.topic-item.selected{background:var(--surface);border-left:2px solid var(--accent)}
.topic-retention{
  width:36px;height:36px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:11px;font-weight:700;flex-shrink:0;
  font-family:var(--mono);
  border:2px solid;
}
.topic-info{flex:1;min-width:0}
.topic-name{font-size:12px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.topic-meta{font-size:10px;color:var(--text3);margin-top:1px}
.topic-urgency{
  font-size:9px;padding:2px 6px;border-radius:4px;font-weight:600;flex-shrink:0;
  font-family:var(--mono);
}
.urg-critical{background:rgba(255,71,87,.2);color:var(--red)}
.urg-soon{background:rgba(255,159,67,.2);color:var(--orange)}
.urg-ok{background:rgba(6,214,160,.15);color:var(--teal)}
.urg-strong{background:rgba(108,99,255,.15);color:var(--accent)}

.add-form{padding:12px 16px;border-top:1px solid var(--border);background:var(--bg)}
.add-form-title{font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px}
.form-row{display:flex;gap:6px;margin-bottom:6px}
.inp{
  flex:1;background:var(--surface);border:1px solid var(--border);
  color:var(--text);font-family:var(--font);font-size:12px;
  padding:7px 10px;border-radius:6px;outline:none;
  transition:border .15s;
}
.inp:focus{border-color:var(--accent)}
.inp::placeholder{color:var(--text3)}
select.inp{cursor:pointer}
.btn{
  padding:7px 12px;border-radius:6px;border:none;
  font-family:var(--font);font-size:12px;font-weight:600;
  cursor:pointer;transition:all .15s;
}
.btn-primary{background:var(--accent);color:white}
.btn-primary:hover{background:#7c75ff}
.btn-sm{padding:4px 10px;font-size:11px}
.btn-outline{background:transparent;border:1px solid var(--border2);color:var(--text2)}
.btn-outline:hover{background:var(--surface2);color:var(--text)}

.section{margin-bottom:24px}
.section-title{
  font-size:14px;font-weight:700;color:var(--text);
  margin-bottom:14px;display:flex;align-items:center;gap:8px;
}
.section-title .dot{width:8px;height:8px;border-radius:50%}

#fcCanvas{
  width:100%;border-radius:8px;
  background:var(--bg3);border:1px solid var(--border);
  display:block;
}

.curve-controls{
  display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;align-items:center;
}
.filter-chip{
  padding:4px 10px;border-radius:6px;font-size:10px;font-weight:600;
  cursor:pointer;border:1px solid var(--border2);
  background:var(--surface2);color:var(--text2);
  transition:all .15s;
}
.filter-chip.active{background:var(--accent);color:white;border-color:var(--accent)}
.filter-chip:hover{border-color:var(--accent2)}

.review-queue{display:flex;flex-direction:column;gap:8px}
.review-card{
  background:var(--surface);border:1px solid var(--border);
  border-radius:8px;padding:12px 14px;
  display:flex;align-items:center;gap:12px;
  cursor:pointer;transition:all .15s;
  position:relative;overflow:hidden;
}
.review-card::before{
  content:'';position:absolute;left:0;top:0;bottom:0;width:3px;
}
.review-card:hover{border-color:var(--border2);transform:translateX(2px)}
.rc-critical::before{background:var(--red)}
.rc-soon::before{background:var(--orange)}
.rc-ok::before{background:var(--teal)}
.rc-strong::before{background:var(--accent)}
.review-card-ret{
  font-family:var(--mono);font-size:20px;font-weight:700;
  min-width:48px;text-align:center;
}
.review-card-info{flex:1}
.review-card-name{font-size:13px;font-weight:600}
.review-card-sub{font-size:11px;color:var(--text2);margin-top:2px}
.review-card-next{font-size:10px;color:var(--text3);font-family:var(--mono)}
.review-actions{display:flex;gap:4px}
.recall-btn{
  width:28px;height:28px;border-radius:6px;border:none;
  cursor:pointer;font-size:11px;font-weight:700;
  transition:all .15s;
  display:flex;align-items:center;justify-content:center;
}
.recall-btn:hover{transform:scale(1.1)}

#kgCanvas{
  width:100%;border-radius:10px;
  background:var(--bg3);border:1px solid var(--border);
  cursor:grab;display:block;
}
#kgCanvas:active{cursor:grabbing}
.kg-controls{display:flex;gap:6px;margin-bottom:10px;flex-wrap:wrap;align-items:center}
.kg-legend{
  display:flex;gap:12px;flex-wrap:wrap;
  padding:10px 14px;background:var(--surface);
  border-radius:8px;border:1px solid var(--border);
  margin-bottom:10px;
}
.kg-legend-item{display:flex;align-items:center;gap:5px;font-size:10px;color:var(--text2)}
.kg-dot{width:8px;height:8px;border-radius:50%}

.tooltip{
  position:fixed;background:var(--surface2);border:1px solid var(--border2);
  border-radius:8px;padding:10px 14px;font-size:12px;
  pointer-events:none;z-index:999;min-width:180px;
  box-shadow:0 8px 24px rgba(0,0,0,.5);
  display:none;
}
.tooltip-title{font-weight:700;margin-bottom:4px;color:var(--text)}
.tooltip-row{display:flex;justify-content:space-between;gap:12px;font-size:11px;color:var(--text2);margin-bottom:2px}

.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px}
.stat-card{
  background:var(--surface);border:1px solid var(--border);
  border-radius:8px;padding:12px;
}
.stat-val{font-family:var(--mono);font-size:22px;font-weight:700;line-height:1}
.stat-label{font-size:10px;color:var(--text3);margin-top:3px;text-transform:uppercase;letter-spacing:.5px}

.topic-detail{
  background:var(--surface);border:1px solid var(--border);
  border-radius:10px;padding:16px;margin-bottom:16px;
  animation:fadeIn .2s ease;
}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}

.sep{border:none;border-top:1px solid var(--border);margin:0}

#miniGraph{width:100%;height:120px;display:block;background:transparent}

.rate-btn{
  width:32px;height:32px;border-radius:6px;border:none;
  font-size:11px;font-weight:700;cursor:pointer;
  transition:all .15s;font-family:var(--mono);
}
.rate-btn:hover{transform:scale(1.08)}

@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
.pulse{animation:pulse 2s infinite}

.search-wrap{padding:10px 16px;border-bottom:1px solid var(--border)}
.search-inp{
  width:100%;background:var(--surface);border:1px solid var(--border);
  color:var(--text);font-family:var(--font);font-size:12px;
  padding:6px 10px;border-radius:6px;outline:none;
  transition:border .15s;
}
.search-inp:focus{border-color:var(--accent)}
.search-inp::placeholder{color:var(--text3)}

/* Loading state */
.loading-state{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  height:200px;gap:12px;color:var(--text3);
}
.loading-spinner{
  width:32px;height:32px;border:2px solid var(--border2);
  border-top-color:var(--accent);border-radius:50%;
  animation:spin .8s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg)}}
</style>

<!-- TOPBAR -->
<div class="topbar">
  <a href="/dashboard" class="logo" style="text-decoration:none">Prep<em>Genius</em></a>
  <div class="topbar-tabs">
    <button class="ttab active" onclick="showTab('fc')">Forgetting Curve</button>
    <button class="ttab" onclick="showTab('kg')">Knowledge Graph</button>
    <button class="ttab" onclick="showTab('queue')">Review Queue</button>
    <a href="/dashboard" class="ttab" style="text-decoration:none">Dashboard</a>
  </div>
  <div class="topbar-right">
    <span class="badge warn" id="dueCount">— due today</span>
    <span class="badge good" id="streakBadge"><%= user.username %></span>
    <div style="width:30px;height:30px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700">
      <%= user.username.charAt(0).toUpperCase() %>
    </div>
  </div>
</div>

<div class="app" id="app">
  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="panel-head">Topics <span id="topicCount">Loading…</span></div>

    <div class="search-wrap">
      <input class="search-inp" id="searchInp" placeholder="Search topics..." oninput="filterTopics(this.value)">
    </div>

    <div id="topicList" style="flex:1;overflow-y:auto">
      <div class="loading-state">
        <div class="loading-spinner"></div>
        <span>Loading topics…</span>
      </div>
    </div>

    <hr class="sep">
    <div class="panel-head">Knowledge Map</div>
    <canvas id="miniGraph"></canvas>

    <hr class="sep">
    <div class="add-form">
      <div class="add-form-title">Add Topic</div>
      <div class="form-row">
        <input class="inp" id="newTopicName" placeholder="Topic name (e.g. Gauss's Law)">
      </div>
      <div class="form-row">
        <select class="inp" id="newTopicSubject">
          <option value="Physics" class="bg-gray-900 text-white">Physics</option>
          <option value="Math" class="bg-gray-900 text-white">Mathematics</option>
          <option value="Chemistry" class="bg-gray-900 text-white">Chemistry</option>
          <option value="Biology" class="bg-gray-900 text-white">Biology</option>
        </select>
        <select class="inp" id="newTopicChapter">
          <option value="Electrostatics" class="bg-gray-900 text-white">Electrostatics</option>
          <option value="Mechanics" class="bg-gray-900 text-white">Mechanics</option>
          <option value="Optics" class="bg-gray-900 text-white">Optics</option>
          <option value="Calculus" class="bg-gray-900 text-white">Calculus</option>
          <option value="Algebra" class="bg-gray-900 text-white">Algebra</option>
          <option value="Organic" class="bg-gray-900 text-white">Organic Chem</option>
          <option value="Inorganic" class="bg-gray-900 text-white">Inorganic Chem</option>
        </select>
      </div>
      <div class="form-row">
        <input class="inp" id="newTopicPrereq" placeholder="Prerequisites (comma-separated names)">
      </div>
      <button class="btn btn-primary" style="width:100%" onclick="addTopic()">+ Add to Knowledge Graph</button>
    </div>
  </div>

  <!-- MAIN PANEL -->
  <div class="main-panel" id="mainContent">
    <div class="loading-state">
      <div class="loading-spinner"></div>
      <span>Loading your study data…</span>
    </div>
  </div>
</div>

<!-- TOOLTIP -->
<div class="tooltip" id="tooltip">
  <div class="tooltip-title" id="tt-title"></div>
  <div class="tooltip-row"><span>Retention</span><span id="tt-ret"></span></div>
  <div class="tooltip-row"><span>Next review</span><span id="tt-next"></span></div>
  <div class="tooltip-row"><span>Interval</span><span id="tt-int"></span></div>
  <div class="tooltip-row"><span>Study count</span><span id="tt-rep"></span></div>
</div>

<script>
// ============================================================
//  SM-2 ALGORITHM — client-side copy for UI calculations only
//  The authoritative calculation happens server-side in services/sm2.js
// ============================================================
function retention(topic, atTime) {
  const t = atTime === undefined ? Date.now() : atTime;
  const lastStudied = new Date(topic.lastStudied).getTime();
  const daysSince = (t - lastStudied) / 86400000;
  const S = Math.max(0.5, topic.interval * 0.7);
  return Math.max(0.02, Math.exp(-daysSince / S));
}

function retentionPercent(topic, atTime) {
  return Math.round(retention(topic, atTime) * 100);
}

function daysUntilDue(topic) {
  const nextDue = new Date(topic.nextDue).getTime();
  return Math.max(0, Math.round((nextDue - Date.now()) / 86400000));
}

function urgency(topic) {
  // Use server-provided urgency if available, otherwise calculate
  if (topic.urgency) return topic.urgency;
  const ret = retentionPercent(topic);
  const overdue = Date.now() > new Date(topic.nextDue).getTime();
  if (overdue && ret < 40) return 'critical';
  if (overdue || ret < 55) return 'soon';
  if (ret < 75) return 'ok';
  return 'strong';
}

function urgencyColor(u) {
  return {critical:'#ff4757',soon:'#ff9f43',ok:'#06d6a0',strong:'#6c63ff'}[u];
}

// ============================================================
//  STATE — loaded from API, not hardcoded
// ============================================================
let topics = [];
let topicMap = {};
let selectedTopic = null;
let activeTab = 'fc';
let searchQuery = '';

// ============================================================
//  SIDEBAR: TOPIC LIST
// ============================================================
function getRetentionStyle(ret) {
  if (ret >= 75) return {color:'#6c63ff',border:'#6c63ff'};
  if (ret >= 55) return {color:'#06d6a0',border:'#06d6a0'};
  if (ret >= 35) return {color:'#ff9f43',border:'#ff9f43'};
  return {color:'#ff4757',border:'#ff4757'};
}

function renderTopicList() {
  const container = document.getElementById('topicList');
  const q = searchQuery.toLowerCase();
  const filtered = topics.filter(t =>
    !q || t.name.toLowerCase().includes(q) || t.subject.toLowerCase().includes(q)
  );

  const order = {critical:0,soon:1,ok:2,strong:3};
  filtered.sort((a,b) => {
    const ua = urgency(a), ub = urgency(b);
    if (order[ua] !== order[ub]) return order[ua] - order[ub];
    return retentionPercent(a) - retentionPercent(b);
  });

  document.getElementById('topicCount').textContent = `${filtered.length} topics`;

  if (filtered.length === 0) {
    container.innerHTML = `<div style="padding:24px 16px;text-align:center;color:var(--text3);font-size:12px">
      No topics yet.<br>Add your first topic below.
    </div>`;
    document.getElementById('dueCount').textContent = `0 due today`;
    return;
  }

  container.innerHTML = filtered.map(t => {
    const ret = retentionPercent(t);
    const style = getRetentionStyle(ret);
    const urg = urgency(t);
    const urgLabels = {critical:'CRITICAL',soon:'DUE SOON',ok:'REVIEW',strong:'STRONG'};
    const isSelected = selectedTopic && selectedTopic.id === t.id;
    return `<div class="topic-item${isSelected?' selected':''}" onclick="selectTopic('${t.id}')">
      <div class="topic-retention" style="color:${style.color};border-color:${style.border}30;background:${style.border}10">
        ${ret}%
      </div>
      <div class="topic-info">
        <div class="topic-name" title="${t.name}">${t.name}</div>
        <div class="topic-meta">${t.subject} · ${t.chapter} · ${t.repetitions} reviews</div>
      </div>
      <span class="topic-urgency urg-${urg}">${urgLabels[urg]}</span>
    </div>`;
  }).join('');

  const due = topics.filter(t => Date.now() >= new Date(t.nextDue).getTime() || retentionPercent(t) < 50).length;
  document.getElementById('dueCount').textContent = `${due} due today`;
}

function filterTopics(q) {
  searchQuery = q;
  renderTopicList();
}

function selectTopic(id) {
  selectedTopic = topicMap[id];
  renderTopicList();
  renderMain();
}

// ============================================================
//  TAB SWITCH
// ============================================================
function showTab(tab) {
  activeTab = tab;
  document.querySelectorAll('.ttab').forEach((el,i) => {
    el.classList.toggle('active', ['fc','kg','queue'][i] === tab);
  });
  renderMain();
}

function renderMain() {
  const el = document.getElementById('mainContent');
  if (activeTab === 'fc') renderFCTab(el);
  else if (activeTab === 'kg') renderKGTab(el);
  else renderQueueTab(el);
}

// ============================================================
//  FORGETTING CURVE TAB
// ============================================================
function renderFCTab(el) {
  const due = topics.filter(t => Date.now() >= new Date(t.nextDue).getTime() || retentionPercent(t) < 50).length;
  const avgRet = topics.length ? Math.round(topics.reduce((s,t) => s + retentionPercent(t), 0) / topics.length) : 0;
  const strong = topics.filter(t => urgency(t) === 'strong').length;
  const topicDetailHTML = selectedTopic ? renderTopicDetail(selectedTopic) : '';

  el.innerHTML = `
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-val" style="color:var(--red)">${due}</div>
        <div class="stat-label">Due for Review</div>
      </div>
      <div class="stat-card">
        <div class="stat-val" style="color:var(--gold)">${avgRet}%</div>
        <div class="stat-label">Avg Retention</div>
      </div>
      <div class="stat-card">
        <div class="stat-val" style="color:var(--teal)">${strong}</div>
        <div class="stat-label">Strong Topics</div>
      </div>
      <div class="stat-card">
        <div class="stat-val" style="color:var(--accent)">${topics.length}</div>
        <div class="stat-label">Total Topics</div>
      </div>
    </div>
    ${topicDetailHTML}
    <div class="section">
      <div class="section-title">
        <div class="dot" style="background:var(--accent)"></div>
        Forgetting Curves — All Topics
      </div>
      <div class="curve-controls">
        <span style="font-size:11px;color:var(--text3)">Filter:</span>
        <div class="filter-chip active" onclick="filterCurve(this,'all')">All</div>
        <div class="filter-chip" onclick="filterCurve(this,'critical')">Critical</div>
        <div class="filter-chip" onclick="filterCurve(this,'Physics')">Physics</div>
        <div class="filter-chip" onclick="filterCurve(this,'Math')">Math</div>
        <div class="filter-chip" onclick="filterCurve(this,'Chemistry')">Chemistry</div>
        <div style="margin-left:auto;font-size:10px;color:var(--text3)">Click curve to select topic</div>
      </div>
      <canvas id="fcCanvas" height="320"></canvas>
      <div style="display:flex;gap:16px;flex-wrap:wrap;margin-top:8px;padding:10px">
        <div style="display:flex;align-items:center;gap:5px;font-size:10px;color:var(--text3)">
          <div style="width:20px;height:2px;background:var(--red)"></div> Critical (&lt;40%)
        </div>
        <div style="display:flex;align-items:center;gap:5px;font-size:10px;color:var(--text3)">
          <div style="width:20px;height:2px;background:var(--orange)"></div> Due soon (40–55%)
        </div>
        <div style="display:flex;align-items:center;gap:5px;font-size:10px;color:var(--text3)">
          <div style="width:20px;height:2px;background:var(--teal)"></div> OK (55–75%)
        </div>
        <div style="display:flex;align-items:center;gap:5px;font-size:10px;color:var(--text3)">
          <div style="width:20px;height:2px;background:var(--accent)"></div> Strong (&gt;75%)
        </div>
        <div style="display:flex;align-items:center;gap:5px;font-size:10px;color:var(--text3)">
          <div style="width:16px;height:1px;background:var(--border2);border-top:1px dashed var(--border2)"></div> Review threshold (50%)
        </div>
      </div>
    </div>
  `;
  setTimeout(() => { drawForgettingCurves('all'); attachFCHover(); }, 50);
}

function renderTopicDetail(t) {
  const ret = retentionPercent(t);
  const urg = urgency(t);
  const style = getRetentionStyle(ret);
  const nextDays = daysUntilDue(t);
  const retHistory = Array.from({length:20}, (_,i) => {
    const daysBack = 20 - i;
    const timepoint = Date.now() - daysBack * 86400000;
    return retentionPercent(t, timepoint);
  });

  // Resolve prerequisite names — prerequisites may be objects (populated) or id strings
