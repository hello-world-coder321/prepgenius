function setKGFilter(el, filter) {
  kgFilter = filter;
  document.querySelectorAll('.filter-chip').forEach(e => e.classList.remove('active'));
  el.classList.add('active');
  initKnowledgeGraph();
}

function resetKGLayout() {
  kgPhysics.nodes.forEach(n => { n.vx = 0; n.vy = 0; });
  const canvas = document.getElementById('kgCanvas');
  if (canvas) initKGPositions(kgPhysics.nodes, canvas.width, 480);
  kgPhysics.running = true;
}

function getNodeColor(t) {
  const ret = retentionPercent(t);
  if (ret >= 75) return '#6c63ff';
  if (ret >= 55) return '#06d6a0';
  if (ret >= 35) return '#ff9f43';
  return '#ff4757';
}

function getSubjectColor(subject) {
  return {Physics:'#ff6584',Math:'#6c63ff',Chemistry:'#4ecdc4',Biology:'#06d6a0'}[subject] || '#9196c4';
}

let dragNode = null, dragOffX = 0, dragOffY = 0;

function initKGPositions(nodes, W, H) {
  const subjectCenters = {
    Physics: {x: W*0.25, y: H*0.3},
    Math: {x: W*0.75, y: H*0.3},
    Chemistry: {x: W*0.5, y: H*0.72},
    Biology: {x: W*0.5, y: H*0.5},
  };
  nodes.forEach((n,i) => {
    const center = subjectCenters[n.topic.subject] || {x:W/2, y:H/2};
    const angle = (i / nodes.length) * Math.PI * 2;
    const r = 60 + Math.random()*40;
    n.x = center.x + Math.cos(angle) * r;
    n.y = center.y + Math.sin(angle) * r;
    n.vx = 0; n.vy = 0;
  });
}

function initKnowledgeGraph() {
  const canvas = document.getElementById('kgCanvas');
  if (!canvas) return;
  const W = canvas.offsetWidth || 700;
  const H = 480;
  canvas.width = W;
  canvas.height = H;

  const visTopics = kgFilter === 'all' ? topics : topics.filter(t => t.subject === kgFilter);
  const nodes = visTopics.map(t => ({
    id: t.id, topic: t,
    x: 0, y: 0, vx: 0, vy: 0,
    r: Math.min(28, Math.max(12, 8 + t.repetitions * 3)),
  }));
  const nodeMap = {};
  nodes.forEach(n => nodeMap[n.id] = n);

  initKGPositions(nodes, W, H);

  // Build edges — prerequisites normalized to strings
  const edges = [];
  visTopics.forEach(t => {
    if (!t.prerequisites) return;
    t.prerequisites.forEach(pid => {
      const pidStr = String(pid);
      if (nodeMap[pidStr]) {
        edges.push({ from: pidStr, to: String(t.id) });
      }
    });
  });

  kgPhysics.nodes = nodes;
  kgPhysics.edges = edges;
  kgPhysics.running = true;
  if (kgPhysics.frame) cancelAnimationFrame(kgPhysics.frame);

  let hoveredNode = null;

  canvas.onmousedown = function(e) {
    const {x, y} = canvasPos(canvas, e);
    const hit = nodes.find(n => Math.hypot(n.x-x, n.y-y) < n.r + 4);
    if (hit) { dragNode = hit; dragOffX = x - hit.x; dragOffY = y - hit.y; }
  };
  canvas.onmousemove = function(e) {
    const {x, y} = canvasPos(canvas, e);
    if (dragNode) { dragNode.x = x - dragOffX; dragNode.y = y - dragOffY; dragNode.vx = 0; dragNode.vy = 0; }
    hoveredNode = nodes.find(n => Math.hypot(n.x-x, n.y-y) < n.r + 4) || null;
    const tt = document.getElementById('tooltip');
    if (hoveredNode) {
      const t = hoveredNode.topic;
      document.getElementById('tt-title').textContent = t.name;
      document.getElementById('tt-ret').textContent = retentionPercent(t) + '%';
      document.getElementById('tt-next').textContent = daysUntilDue(t) === 0 ? 'TODAY' : `in ${daysUntilDue(t)} days`;
      document.getElementById('tt-int').textContent = t.interval + ' days';
      document.getElementById('tt-rep').textContent = t.repetitions;
      tt.style.display = 'block';
      tt.style.left = (e.clientX + 12) + 'px';
      tt.style.top = (e.clientY - 40) + 'px';
      canvas.style.cursor = 'pointer';
    } else {
      tt.style.display = 'none';
      canvas.style.cursor = dragNode ? 'grabbing' : 'grab';
    }
  };
  canvas.onmouseup = function() { dragNode = null; };
  canvas.onmouseleave = function() {
    dragNode = null;
    document.getElementById('tooltip').style.display = 'none';
    canvas.style.cursor = 'grab';
  };
  canvas.onclick = function(e) {
    const {x, y} = canvasPos(canvas, e);
    const hit = nodes.find(n => Math.hypot(n.x-x, n.y-y) < n.r+4);
    if (hit) {
      selectTopic(hit.id);
      const info = document.getElementById('kgSelectedInfo');
      if (info) info.innerHTML = renderTopicDetail(topicMap[hit.id]);
    }
  };

  function tick() {
    if (!document.getElementById('kgCanvas')) { cancelAnimationFrame(kgPhysics.frame); return; }
    if (kgPhysics.running) {
      const W2 = canvas.width, H2 = canvas.height;
      const k = 0.05, repulsion = 4000, damping = 0.85;
      nodes.forEach(n => { if (n === dragNode) return; n.vx *= damping; n.vy *= damping; });
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i+1; j < nodes.length; j++) {
          const a = nodes[i], b = nodes[j];
          const dx = b.x - a.x, dy = b.y - a.y;
          const dist = Math.max(1, Math.hypot(dx, dy));
          if (dist < (a.r + b.r + 20) * 3) {
            const force = repulsion / (dist * dist);
            const fx = (dx/dist) * force, fy = (dy/dist) * force;
            if (a !== dragNode) { a.vx -= fx; a.vy -= fy; }
            if (b !== dragNode) { b.vx += fx; b.vy += fy; }
          }
        }
      }
      edges.forEach(e => {
        const a = nodeMap[e.from], b = nodeMap[e.to];
        if (!a || !b) return;
        const dx = b.x - a.x, dy = b.y - a.y;
        const dist = Math.max(1, Math.hypot(dx, dy));
        const targetDist = (a.r + b.r) * 3.5;
        const force = k * (dist - targetDist);
        const fx = (dx/dist) * force, fy = (dy/dist) * force;
        if (a !== dragNode) { a.vx += fx; a.vy += fy; }
        if (b !== dragNode) { b.vx -= fx; b.vy -= fy; }
      });
      nodes.forEach(n => {
        if (n === dragNode) return;
        n.vx += (W2/2 - n.x) * 0.002;
        n.vy += (H2/2 - n.y) * 0.002;
        n.x += n.vx; n.y += n.vy;
        n.x = Math.max(n.r+5, Math.min(W2-n.r-5, n.x));
        n.y = Math.max(n.r+5, Math.min(H2-n.r-5, n.y));
      });
    }
    drawKG(canvas, nodes, edges, nodeMap, hoveredNode, selectedTopic);
    kgPhysics.frame = requestAnimationFrame(tick);
  }
  tick();
}

function canvasPos(canvas, e) {
  const rect = canvas.getBoundingClientRect();
  return { x: e.clientX - rect.left, y: e.clientY - rect.top };
}

function drawKG(canvas, nodes, edges, nodeMap, hoveredNode, selTopic) {
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  ctx.clearRect(0, 0, W, H);
  ctx.fillStyle = '#0e0f1a'; ctx.fillRect(0, 0, W, H);
  ctx.strokeStyle = '#1a1b2e'; ctx.lineWidth = 0.5;
  for (let x = 0; x < W; x += 60) { ctx.beginPath(); ctx.moveTo(x,0); ctx.lineTo(x,H); ctx.stroke(); }
  for (let y = 0; y < H; y += 60) { ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke(); }

  edges.forEach(e => {
    const a = nodeMap[e.from], b = nodeMap[e.to];
    if (!a || !b) return;
    const selId = selTopic ? selTopic.id : null;
    const isHighlighted = selId && (a.id === selId || b.id === selId);
    const isWeak = retentionPercent(a.topic) < 50 || retentionPercent(b.topic) < 50;
    ctx.globalAlpha = isHighlighted ? 0.9 : (selId ? 0.1 : 0.3);
    ctx.strokeStyle = isWeak ? '#ff4757' : '#6c63ff';
    ctx.lineWidth = isHighlighted ? 2 : 1;
    ctx.setLineDash(isWeak ? [4,3] : []);
    const mx = (a.x + b.x)/2 + (b.y - a.y)*0.15;
    const my = (a.y + b.y)/2 - (b.x - a.x)*0.15;
    ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.quadraticCurveTo(mx, my, b.x, b.y); ctx.stroke();
    ctx.setLineDash([]);
    if (isHighlighted) {
      const angle = Math.atan2(b.y - my, b.x - mx);
      const ax = b.x - Math.cos(angle) * (b.r + 2);
      const ay = b.y - Math.sin(angle) * (b.r + 2);
      ctx.beginPath();
      ctx.moveTo(ax, ay); ctx.lineTo(ax - 8*Math.cos(angle-0.4), ay - 8*Math.sin(angle-0.4));
      ctx.moveTo(ax, ay); ctx.lineTo(ax - 8*Math.cos(angle+0.4), ay - 8*Math.sin(angle+0.4));
      ctx.strokeStyle = isWeak ? '#ff4757' : '#6c63ff'; ctx.lineWidth = 1.5; ctx.stroke();
    }
    ctx.globalAlpha = 1;
  });

  nodes.forEach(n => {
    const t = n.topic;
    const color = getNodeColor(t);
    const subColor = getSubjectColor(t.subject);
    const isHovered = hoveredNode && hoveredNode.id === n.id;
    const isSelected = selTopic && selTopic.id === n.id;
    const isPrereq = selTopic && selTopic.prerequisites && selTopic.prerequisites.some(p => {
      return String(p) === String(n.id);
    });
    const isDependent = selTopic && n.topic.prerequisites && n.topic.prerequisites.some(p => {
      return String(p) === String(selTopic.id);
    });
    const alpha = selTopic ? (isSelected || isPrereq || isDependent ? 1 : 0.3) : 1;
    ctx.globalAlpha = alpha;
    const radius = isHovered ? n.r + 3 : n.r;

    if (isSelected || urgency(t) === 'critical') {
      ctx.beginPath(); ctx.arc(n.x, n.y, radius + 8, 0, Math.PI*2);
      const grd = ctx.createRadialGradient(n.x, n.y, radius, n.x, n.y, radius+8);
      grd.addColorStop(0, color+'60'); grd.addColorStop(1, color+'00');
      ctx.fillStyle = grd; ctx.fill();
    }

    ctx.beginPath(); ctx.arc(n.x, n.y, radius + 3, 0, Math.PI*2);
    ctx.strokeStyle = subColor + '40'; ctx.lineWidth = 2; ctx.stroke();

    ctx.beginPath(); ctx.arc(n.x, n.y, radius, 0, Math.PI*2);
    ctx.fillStyle = color + '22'; ctx.fill();

    ctx.beginPath(); ctx.arc(n.x, n.y, radius, 0, Math.PI*2);
    ctx.strokeStyle = isSelected ? 'white' : color;
    ctx.lineWidth = isSelected ? 2.5 : 1.5; ctx.stroke();

    const retFrac = retention(t);
    ctx.beginPath(); ctx.moveTo(n.x, n.y);
    ctx.arc(n.x, n.y, radius - 2, -Math.PI/2, -Math.PI/2 + retFrac * Math.PI * 2);
    ctx.closePath(); ctx.fillStyle = color + '40'; ctx.fill();

    ctx.fillStyle = isSelected ? 'white' : '#e8eaf6';
    ctx.font = `${isSelected ? '600 ' : ''}${Math.min(11, Math.max(8, n.r * 0.6))}px Space Grotesk`;
    ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    const maxChars = Math.floor(radius * 1.5 / 4);
    const label = t.name.length > maxChars ? t.name.substring(0, maxChars-1) + '…' : t.name;
    ctx.shadowColor = '#07080f'; ctx.shadowBlur = 4;
    ctx.fillText(label, n.x, n.y - 2); ctx.shadowBlur = 0;

    if (radius > 16) {
      ctx.font = '500 9px JetBrains Mono';
      ctx.fillStyle = color;
      ctx.fillText(retentionPercent(t) + '%', n.x, n.y + radius*0.55);
    }
    ctx.globalAlpha = 1;
  });

  const subjects = [...new Set(nodes.map(n => n.topic.subject))];
  subjects.forEach(s => {
    const sNodes = nodes.filter(n => n.topic.subject === s);
    if (!sNodes.length) return;
    const cx = sNodes.reduce((sum,n) => sum+n.x,0)/sNodes.length;
    const cy = sNodes.reduce((sum,n) => sum+n.y,0)/sNodes.length;
    ctx.globalAlpha = 0.15;
    ctx.fillStyle = getSubjectColor(s);
    ctx.font = '700 13px Space Grotesk';
    ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
    ctx.fillText(s.toUpperCase(), cx, cy - 50);
    ctx.globalAlpha = 1;
  });
}

// ============================================================
//  MINI GRAPH (sidebar)
// ============================================================
function drawMiniGraph() {
  const canvas = document.getElementById('miniGraph');
  if (!canvas) return;
  const W = canvas.offsetWidth || 280;
  const H = 120;
  canvas.width = W; canvas.height = H;
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0,0,W,H);
  const pad = 12;
  const subjectPos = {
    Physics:{x:W*0.25,y:H*0.35}, Math:{x:W*0.75,y:H*0.35},
    Chemistry:{x:W*0.5,y:H*0.75}, Biology:{x:W*0.5,y:H*0.5}
  };
  topics.forEach(t => {
    if (!t.prerequisites) return;
    t.prerequisites.forEach(p => {
      const pid = typeof p === 'object' ? (p._id || p.id) : p;
      const pt = topicMap[pid];
      if (!pt) return;
      const sc = subjectPos[t.subject], sp = subjectPos[pt.subject];
      if (!sc || !sp) return;
      ctx.beginPath(); ctx.strokeStyle = '#6c63ff30'; ctx.lineWidth = 0.5;
      ctx.moveTo(sc.x + (Math.random()-0.5)*30, sc.y + (Math.random()-0.5)*20);
      ctx.lineTo(sp.x + (Math.random()-0.5)*30, sp.y + (Math.random()-0.5)*20);
      ctx.stroke();
    });
  });
  topics.forEach((t,i) => {
    const sp = subjectPos[t.subject];
    if (!sp) return;
    const angle = (i % 8) / 8 * Math.PI * 2;
    const r = 15 + (i % 3) * 8;
    const x = Math.max(pad, Math.min(W-pad, sp.x + Math.cos(angle)*r));
    const y = Math.max(pad, Math.min(H-pad, sp.y + Math.sin(angle)*r));
    const color = getNodeColor(t);
    ctx.beginPath(); ctx.arc(x, y, 3, 0, Math.PI*2);
    ctx.fillStyle = color + '90'; ctx.fill();
    ctx.strokeStyle = color; ctx.lineWidth = 0.8; ctx.stroke();
  });
  Object.entries(subjectPos).forEach(([s, pos]) => {
    if (!topics.filter(t => t.subject === s).length) return;
    ctx.fillStyle = getSubjectColor(s) + 'a0';
    ctx.font = '9px Space Grotesk'; ctx.textAlign = 'center';
    ctx.fillText(s, pos.x, pos.y - 16);
  });
}

// ============================================================
//  ADD TOPIC — saves to MongoDB via API
// ============================================================
async function deleteTopic(id) {
  if (!confirm('Delete this topic? This cannot be undone.')) return;

  try {
    const res = await fetch(`/srs/topics/${id}`, { method: 'DELETE' });
    if (!res.ok) { showToast('Failed to delete topic', 'var(--red)'); return; }

    // Remove from local state
    topics = topics.filter(t => t.id !== id);
    delete topicMap[id];

    // Remove from other topics' prerequisites locally
    topics.forEach(t => {
      t.prerequisites = (t.prerequisites || []).filter(p => String(p) !== String(id));
    });

    // Clear selection if deleted topic was selected
    if (selectedTopic && selectedTopic.id === id) selectedTopic = null;

    renderTopicList();
    renderMain();
    drawMiniGraph();
    showToast('Topic deleted', 'var(--red)');
  } catch (e) {
    showToast('Network error — try again', 'var(--red)');
  }
}
async function addTopic() {
  const name = document.getElementById('newTopicName').value.trim();
  if (!name) { showToast('Please enter a topic name', 'var(--red)'); return; }

  const btn = document.querySelector('.add-form .btn-primary');
  btn.textContent = 'Saving…'; btn.disabled = true;

  try {
    const res = await fetch('/srs/topics', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name,
        subject: document.getElementById('newTopicSubject').value,
        chapter: document.getElementById('newTopicChapter').value,
        exam: '<%= user.selectedExam || "JEE" %>',
        prerequisites: document.getElementById('newTopicPrereq').value
          .split(',').map(s => s.trim()).filter(Boolean)
      })
    });
    if (!res.ok) { showToast('Failed to save topic', 'var(--red)'); return; }
    const newTopic = await res.json();
    newTopic.id = String(newTopic._id || newTopic.id);
    newTopic.prerequisites = (newTopic.prerequisites || []).map(p =>
      typeof p === 'object' ? String(p._id || p.id) : String(p)
    );
    topics.push(newTopic);
    topicMap[newTopic.id] = newTopic;
    document.getElementById('newTopicName').value = '';
    document.getElementById('newTopicPrereq').value = '';
    renderTopicList();
    renderMain();
    drawMiniGraph();
    showToast(`"${name}" added!`, 'var(--teal)');
  } catch (e) {
    showToast('Network error — try again', 'var(--red)');
  } finally {
    btn.textContent = '+ Add to Knowledge Graph'; btn.disabled = false;
  }
}

// ============================================================
//  BOOT — load topics from MongoDB via API
// ============================================================
document.addEventListener('DOMContentLoaded', async () => {
  try {
    const res = await fetch('/srs/topics');
    if (res.status === 401) { window.location.href = '/login'; return; }
    if (!res.ok) throw new Error('Failed to load topics');

    const data = await res.json();
    topics = data.map(t => ({
      ...t,
      id: String(t._id || t.id),
      prerequisites: (t.prerequisites || []).map(p =>
        typeof p === 'object' ? String(p._id || p.id) : String(p)
      )
    }));
    topicMap = {};
    topics.forEach(t => topicMap[t.id] = t);

    renderTopicList();
    renderMain();
    drawMiniGraph();
    window.addEventListener('resize', drawMiniGraph);
  } catch (e) {
    document.getElementById('mainContent').innerHTML = `
      <div class="loading-state" style="color:var(--red)">
        <div style="font-size:24px">⚠</div>
        <span>Failed to load topics. <a href="/srs/page" style="color:var(--accent)">Retry</a></span>
      </div>`;
    document.getElementById('topicList').innerHTML = '';
    document.getElementById('topicCount').textContent = 'Error';
  }
});
</script>

