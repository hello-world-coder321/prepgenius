          <span style="font-size:10px;padding:2px 8px;border-radius:4px;background:var(--surface2);color:var(--text2)">${t.repetitions} reviews</span>
          <span style="font-size:10px;padding:2px 8px;border-radius:4px;background:var(--surface2);color:var(--text2)">EF: ${Number(t.easeFactor).toFixed(2)}</span>
          <span style="font-size:10px;padding:2px 8px;border-radius:4px;background:var(--surface2);color:var(--text2)">Interval: ${t.interval}d</span>
