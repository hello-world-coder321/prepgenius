// ============================================================
//  DRAW FORGETTING CURVES
// ============================================================
let curveFilter = 'all';
function filterCurve(el, filter) {
  curveFilter = filter;
  document.querySelectorAll('.filter-chip').forEach(e => e.classList.remove('active'));
  el.classList.add('active');
  drawForgettingCurves(filter);
}

function drawForgettingCurves(filter) {
  const canvas = document.getElementById('fcCanvas');
  if (!canvas) return;
  const W = canvas.offsetWidth || 700;
  const H = 320;
  canvas.width = W;
  canvas.height = H;
  const ctx = canvas.getContext('2d');
  const pad = {top:30, right:20, bottom:40, left:50};
  const cw = W - pad.left - pad.right;
  const ch = H - pad.top - pad.bottom;

  ctx.clearRect(0,0,W,H);
  ctx.fillStyle = '#0e0f1a';
  ctx.fillRect(0,0,W,H);

  ctx.strokeStyle = '#1a1b2e';
  ctx.lineWidth = 1;
  for (let i = 0; i <= 5; i++) {
    const y = pad.top + ch * (1 - i/5);
    ctx.beginPath(); ctx.moveTo(pad.left, y); ctx.lineTo(pad.left+cw, y); ctx.stroke();
    ctx.fillStyle = '#5a5f8a';
    ctx.font = '10px JetBrains Mono, monospace';
    ctx.textAlign = 'right';
    ctx.fillText(i*20+'%', pad.left - 6, y + 4);
  }

  ctx.fillStyle = '#5a5f8a';
  ctx.font = '10px JetBrains Mono, monospace';
  ctx.textAlign = 'center';
  for (let d = 0; d <= 30; d += 5) {
    const x = pad.left + cw * d / 30;
    ctx.fillText(d+'d', x, H - 6);
    if (d > 0) {
      ctx.strokeStyle = '#141526'; ctx.lineWidth = 0.5;
      ctx.beginPath(); ctx.moveTo(x, pad.top); ctx.lineTo(x, pad.top+ch); ctx.stroke();
    }
  }

  const threshY = pad.top + ch * 0.5;
  ctx.setLineDash([5,4]); ctx.strokeStyle = '#353860'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(pad.left, threshY); ctx.lineTo(pad.left+cw, threshY); ctx.stroke();
  ctx.setLineDash([]);
  ctx.fillStyle = '#353860'; ctx.font = '9px JetBrains Mono'; ctx.textAlign = 'left';
  ctx.fillText('Review threshold', pad.left+4, threshY - 4);

  ctx.strokeStyle = '#353860'; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(pad.left, pad.top); ctx.lineTo(pad.left, pad.top+ch); ctx.lineTo(pad.left+cw, pad.top+ch); ctx.stroke();

  let toShow = topics;
  if (filter === 'critical') toShow = topics.filter(t => urgency(t) === 'critical' || urgency(t) === 'soon');
  else if (filter !== 'all') toShow = topics.filter(t => t.subject === filter);

  const DAYS_RANGE = 30;
  const now = Date.now();
  canvas._curveHits = [];

  toShow.forEach(t => {
    const urg = urgency(t);
    const color = urgencyColor(urg);
    const isSelected = selectedTopic && selectedTopic.id === t.id;
    const alpha = isSelected ? 1 : (selectedTopic ? 0.25 : 0.7);
    const lastStudied = new Date(t.lastStudied).getTime();

    ctx.beginPath();
    ctx.strokeStyle = color;
    ctx.lineWidth = isSelected ? 2.5 : 1.2;
    ctx.globalAlpha = alpha;

    for (let d = 0; d <= DAYS_RANGE; d++) {
      const timeOffset = (d - (now - lastStudied) / 86400000);
      const R = Math.max(0.02, Math.exp(-Math.max(0, timeOffset) / Math.max(0.5, t.interval * 0.7)));
      const x = pad.left + cw * d / DAYS_RANGE;
      const y = pad.top + ch * (1 - R);
      if (d === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
    }
    ctx.stroke();
    ctx.globalAlpha = 1;

    const daysSince = (now - lastStudied) / 86400000;
    const currentX = pad.left + cw * Math.min(daysSince, DAYS_RANGE) / DAYS_RANGE;
    const ret = retention(t);
    const currentY = pad.top + ch * (1 - ret);

    ctx.beginPath();
    ctx.arc(currentX, currentY, isSelected ? 5 : 3, 0, Math.PI*2);
    ctx.fillStyle = color;
    ctx.globalAlpha = alpha;
    ctx.fill();
    ctx.globalAlpha = 1;

    if (isSelected || (urg === 'critical' && !selectedTopic)) {
      ctx.font = isSelected ? '600 11px Space Grotesk' : '10px Space Grotesk';
      ctx.fillStyle = color;
      ctx.globalAlpha = 0.9;
      ctx.textAlign = 'left';
      const labelX = Math.min(currentX + 6, pad.left + cw - 80);
      ctx.fillText(t.name.length > 18 ? t.name.substring(0,16)+'…' : t.name, labelX, currentY - 6);
      ctx.globalAlpha = 1;
    }

    const nextDue = new Date(t.nextDue).getTime();
    const dueX = pad.left + cw * Math.min((nextDue - now + daysSince*86400000) / (86400000*DAYS_RANGE), 1);
    if (dueX < pad.left + cw) {
      ctx.strokeStyle = color; ctx.lineWidth = 0.8; ctx.globalAlpha = 0.4;
      ctx.setLineDash([3,3]);
      ctx.beginPath(); ctx.moveTo(dueX, pad.top); ctx.lineTo(dueX, pad.top+ch); ctx.stroke();
      ctx.setLineDash([]); ctx.globalAlpha = 1;
    }

    canvas._curveHits.push({topic: t, cx: currentX, cy: currentY});
  });

  ctx.strokeStyle = '#6c63ff'; ctx.lineWidth = 1; ctx.setLineDash([4,3]);
  ctx.beginPath(); ctx.moveTo(pad.left, pad.top); ctx.lineTo(pad.left, pad.top+ch); ctx.stroke();
  ctx.setLineDash([]);
  ctx.fillStyle = '#6c63ff'; ctx.font = '9px Space Grotesk'; ctx.textAlign = 'center';
  ctx.fillText('NOW', pad.left, pad.top - 10);
}

function attachFCHover() {
  const canvas = document.getElementById('fcCanvas');
  if (!canvas) return;
  canvas.onmousemove = function(e) {
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left, my = e.clientY - rect.top;
    if (!canvas._curveHits) return;
    const hit = canvas._curveHits.find(h => Math.hypot(h.cx-mx, h.cy-my) < 12);
    const tt = document.getElementById('tooltip');
    if (hit) {
      const t = hit.topic;
      document.getElementById('tt-title').textContent = t.name;
      document.getElementById('tt-ret').textContent = retentionPercent(t) + '%';
      document.getElementById('tt-next').textContent = daysUntilDue(t) === 0 ? 'TODAY' : `in ${daysUntilDue(t)} days`;
      document.getElementById('tt-int').textContent = t.interval + ' days';
      document.getElementById('tt-rep').textContent = t.repetitions;
      tt.style.display = 'block';
      tt.style.left = (e.clientX + 12) + 'px';
      tt.style.top = (e.clientY - 40) + 'px';
    } else {
      tt.style.display = 'none';
    }
  };
  canvas.onmouseleave = () => { document.getElementById('tooltip').style.display = 'none'; };
  canvas.onclick = function(e) {
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left, my = e.clientY - rect.top;
    if (!canvas._curveHits) return;
    const hit = canvas._curveHits.find(h => Math.hypot(h.cx-mx, h.cy-my) < 12);
    if (hit) selectTopic(hit.topic.id);
  };
}

// ============================================================
//  RATE RECALL — calls API, updates local state from response
// ============================================================
async function rateRecall(id, q) {
  const msgs = ['Blackout — resetting to day 1','Very hard — try again tomorrow','Hard — short interval','OK — slight boost','Good — interval extended!','Perfect! — major interval boost'];
  const colors = ['var(--red)','#ff6b81','var(--orange)','var(--gold)','var(--teal)','var(--accent)'];
  showToast(msgs[q], colors[q]);

  try {
    const res = await fetch('/srs/review', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ topicId: id, quality: q })
    });
    if (!res.ok) { showToast('Failed to save review', 'var(--red)'); return; }
    const updated = await res.json();
    updated.id = String(updated._id || updated.id);
    updated.prerequisites = (updated.prerequisites || []).map(p =>
      typeof p === 'object' ? String(p._id || p.id) : String(p)
    );
    topicMap[id] = updated;
    topics = topics.map(t => t.id === id ? updated : t);
    renderTopicList();
    renderMain();
  } catch (e) {
    showToast('Network error — try again', 'var(--red)');
  }
}

function showToast(msg, color) {
  let toast = document.getElementById('toast');
  if (!toast) {
    toast = document.createElement('div');
    toast.id = 'toast';
    Object.assign(toast.style, {
      position:'fixed',bottom:'20px',right:'20px',zIndex:'9999',
      padding:'10px 16px',borderRadius:'8px',fontSize:'13px',fontWeight:'600',
      transition:'all .3s',transform:'translateY(20px)',opacity:'0'
    });
    document.body.appendChild(toast);
  }
  toast.textContent = msg;
  toast.style.background = color;
  toast.style.color = 'white';
  toast.style.transform = 'translateY(0)';
  toast.style.opacity = '1';
  setTimeout(() => { toast.style.opacity='0'; toast.style.transform='translateY(10px)'; }, 2200);
}

