        <div class="kg-legend-item"><div class="kg-dot" style="background:var(--teal)"></div>55–75% OK</div>
        <div class="kg-legend-item"><div class="kg-dot" style="background:var(--orange)"></div>35–55% Soon</div>
        <div class="kg-legend-item"><div class="kg-dot" style="background:var(--red)"></div>&lt;35% Critical</div>
        <div style="margin-left:auto;font-size:10px;color:var(--text3)">Node size = study count · Drag to rearrange</div>
      </div>
      <canvas id="kgCanvas" height="480"></canvas>
      <div id="kgSelectedInfo" style="margin-top:12px"></div>
    </div>
  `;
  setTimeout(() => initKnowledgeGraph(), 80);
