function renderQueueTab(el) {
  const now = Date.now();
  const dueTopics = topics
    .filter(t => now >= new Date(t.nextDue).getTime() || retentionPercent(t) < 50)
    .sort((a,b) => retentionPercent(a) - retentionPercent(b));

  const upcoming = topics
    .filter(t => now < new Date(t.nextDue).getTime() && retentionPercent(t) >= 50)
    .sort((a,b) => new Date(a.nextDue) - new Date(b.nextDue))
    .slice(0, 10);

  el.innerHTML = `
    <div class="section">
      <div class="section-title">
        <div class="dot" style="background:var(--red)"></div>
        Due Now — ${dueTopics.length} topics
      </div>
      <div class="review-queue">
        ${dueTopics.length === 0
          ? '<div style="color:var(--text3);font-size:12px;padding:16px;background:var(--surface);border-radius:8px;text-align:center">All caught up! No topics due today.</div>'
          : dueTopics.map(t => {
              const ret = retentionPercent(t);
              const urg = urgency(t);
              const color = urgencyColor(urg);
              const overdue = Math.round((now - new Date(t.nextDue).getTime()) / 86400000);
              return `<div class="review-card rc-${urg}">
                <div class="review-card-ret" style="color:${color}">${ret}%</div>
                <div class="review-card-info" onclick="selectTopic('${t.id}');showTab('fc')">
                  <div class="review-card-name">${t.name}</div>
                  <div class="review-card-sub">${t.subject} · ${t.chapter} · ${t.repetitions} past reviews · EF ${Number(t.easeFactor).toFixed(2)}</div>
                  <div class="review-card-next" style="color:${color}">${overdue > 0 ? `${overdue}d overdue` : 'Due today'}</div>
                </div>
                <div class="review-actions">
                  ${[1,3,5].map(q => {
                    const labels = {1:'Hard',3:'OK',5:'Easy'};
                    const btnColors = {1:'#ff4757',3:'#ffd166',5:'#06d6a0'};
                    return `<button class="recall-btn" onclick="rateRecall('${t.id}',${q})"
                      style="background:${btnColors[q]}20;color:${btnColors[q]};border:1px solid ${btnColors[q]}30;font-size:9px;width:40px;height:40px;border-radius:6px;flex-direction:column;gap:0">
                      <span style="font-size:11px;font-weight:700">${q}</span>
                      <span style="font-size:8px">${labels[q]}</span>
                    </button>`;
                  }).join('')}
                </div>
              </div>`;
            }).join('')}
      </div>
    </div>
    <div class="section">
      <div class="section-title">
        <div class="dot" style="background:var(--teal)"></div>
        Upcoming — Next 10 Scheduled Revisions
      </div>
      <div style="display:flex;flex-direction:column;gap:6px">
        ${upcoming.length === 0
          ? '<div style="color:var(--text3);font-size:12px;padding:16px;background:var(--surface);border-radius:8px;text-align:center">No upcoming revisions scheduled yet.</div>'
          : upcoming.map(t => {
              const dDue = daysUntilDue(t);
              const ret = retentionPercent(t);
              const projRet = retentionPercent(t, new Date(t.nextDue).getTime());
              const color = urgencyColor(urgency(t));
              return `<div style="background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px 14px;display:flex;align-items:center;gap:12px;cursor:pointer"
                onmouseover="this.style.background='var(--surface2)'" onmouseout="this.style.background='var(--surface)'"
                onclick="selectTopic('${t.id}');showTab('fc')">
                <div style="font-family:var(--mono);font-size:13px;font-weight:700;min-width:32px;text-align:center;color:var(--text2)">+${dDue}d</div>
                <div style="flex:1">
                  <div style="font-size:12px;font-weight:600">${t.name}</div>
                  <div style="font-size:10px;color:var(--text3)">${t.subject} · Projected retention at review: ${projRet}%</div>
                </div>
                <div style="text-align:right">
                  <div style="font-family:var(--mono);font-size:13px;color:${color};font-weight:600">${ret}%</div>
                  <div style="font-size:9px;color:var(--text3)">now</div>
                </div>
              </div>`;
            }).join('')}
      </div>
    </div>
  `;
}

