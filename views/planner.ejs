<%- include('partials/header') %>

<main class="min-h-screen pt-20 pb-12 px-4">
  <div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-6 gap-4">
      <div>
        <a href="/dashboard" class="text-sm text-gray-500 hover:text-gray-300 transition-colors flex items-center gap-1 mb-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg> Back to Dashboard
        </a>
        <h1 class="font-display text-2xl font-bold text-white">📅 Study Planner</h1>
        <p class="text-sm text-gray-500 mt-1">AI-generated daily plan for <span class="text-brand-400 font-semibold"><%= exam %></span></p>
      </div>
      <div class="flex flex-wrap gap-2">
        <button onclick="generateSmartPlan()" id="smart-generate-btn"
          class="relative overflow-hidden text-sm font-semibold flex items-center gap-2 px-4 py-2.5 rounded-xl text-white transition-all duration-300 hover:scale-[1.03] active:scale-95"
          style="background: linear-gradient(135deg, #6366f1, #a855f7, #ec4899); box-shadow: 0 4px 20px rgba(139, 92, 246, 0.4);">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          ⚡ Generate Smart Plan
          <span class="absolute inset-0 bg-white/10 opacity-0 hover:opacity-100 transition-opacity"></span>
        </button>

      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- ── Smart Plan Section (6 Syllabus + 2 Revision Tasks) ── -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <div id="smart-plan-section" class="mb-8" style="display:none;">
      <!-- Smart Progress Bar -->
      <div class="glass-card p-4 mb-4 border border-purple-500/20">
        <div class="flex items-center justify-between mb-2">
          <div class="flex items-center gap-2">
            <span class="text-lg">⚡</span>
            <span class="text-sm font-semibold text-purple-300">Smart Plan Progress</span>
          </div>
          <span class="text-sm font-bold text-purple-400" id="smart-progress-text">0 / 0 tasks</span>
        </div>
        <div class="w-full h-2.5 bg-white/5 rounded-full overflow-hidden">
          <div id="smart-progress-bar" class="h-full rounded-full transition-all duration-700"
            style="width: 0%; background: linear-gradient(90deg, #6366f1, #a855f7, #ec4899);"></div>
        </div>
        <div class="flex items-center gap-4 mt-3">
          <span class="flex items-center gap-1 text-xs text-gray-400">
            <span class="w-2 h-2 rounded-full bg-emerald-500 inline-block"></span> Syllabus: <span id="smart-syllabus-count" class="text-emerald-400 font-bold">0</span>
          </span>
          <span class="flex items-center gap-1 text-xs text-gray-400">
            <span class="w-2 h-2 rounded-full bg-amber-500 inline-block"></span> Revision: <span id="smart-revision-count" class="text-amber-400 font-bold">0</span>
          </span>
        </div>
      </div>

      <!-- Info banner for existing plan -->
      <div id="smart-existing-banner" class="hidden mb-4 p-3 rounded-xl border border-blue-500/20 bg-blue-500/5 flex items-center gap-2">
        <svg class="w-4 h-4 text-blue-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span class="text-xs text-blue-300">Smart plan already exists for today. Showing your existing plan.</span>
      </div>

      <!-- Syllabus Tasks Group -->
      <div id="smart-syllabus-group" class="mb-4" style="display:none;">
        <div class="flex items-center gap-2 mb-3 ml-1">
          <span class="text-lg">📘</span>
          <h3 class="text-sm font-bold text-white uppercase tracking-wider">Syllabus Tasks</h3>
          <span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-500/20 text-emerald-400 border border-emerald-500/30" id="syllabus-badge">New Topic</span>
        </div>
        <div id="smart-syllabus-tasks" class="space-y-2"></div>
      </div>

      <!-- Revision Tasks Group -->
      <div id="smart-revision-group" class="mb-4" style="display:none;">
        <div class="flex items-center gap-2 mb-3 ml-1">
          <span class="text-lg">🔁</span>
          <h3 class="text-sm font-bold text-white uppercase tracking-wider">Revision Tasks</h3>
          <span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-amber-500/20 text-amber-400 border border-amber-500/30">Revision</span>
        </div>
        <div id="smart-revision-tasks" class="space-y-2"></div>
      </div>

      <!-- Empty state for smart plan -->
      <div id="smart-empty-state" class="hidden glass-card p-8 text-center">
        <span class="text-3xl block mb-3">🧠</span>
        <p class="text-sm text-gray-400">No topics available for smart plan generation. Add topics to your syllabus or revision collection first.</p>
      </div>
    </div>


  </div>
</main>

<script>
  // ════════════════════════════════════════════
  // ── Smart Plan Functions ──
  // ════════════════════════════════════════════

  /**
   * Generate smart plan: 6 syllabus + 2 revision tasks
   */
  async function generateSmartPlan() {
    const btn = document.getElementById('smart-generate-btn');
    const originalHTML = btn.innerHTML;
    btn.innerHTML = '<div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div> Generating...';
    btn.disabled = true;
    btn.style.opacity = '0.7';

    try {
      const res = await fetch('/planner/smart-generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
      });
      const data = await res.json();

      if (data.error) throw new Error(data.error);

      renderSmartPlan(data);

      // Show the existing-plan banner if applicable
      if (data.isExisting) {
        document.getElementById('smart-existing-banner').classList.remove('hidden');
      }

    } catch (e) {
      alert('Failed to generate smart plan: ' + e.message);
    } finally {
      btn.innerHTML = originalHTML;
      btn.disabled = false;
      btn.style.opacity = '1';
    }
  }

  /**
   * Render the smart plan UI with grouped tasks
   */
  function renderSmartPlan(data) {
    const section = document.getElementById('smart-plan-section');
    section.style.display = 'block';

    // Update progress stats
    updateSmartProgress(data.stats);

    // Render syllabus tasks
    const syllabusContainer = document.getElementById('smart-syllabus-tasks');
    const syllabusGroup = document.getElementById('smart-syllabus-group');
    if (data.syllabusTasks && data.syllabusTasks.length > 0) {
      syllabusGroup.style.display = 'block';
      syllabusContainer.innerHTML = data.syllabusTasks.map(task => createSmartTaskHTML(task, 'syllabus')).join('');
    } else {
      syllabusGroup.style.display = 'none';
    }

    // Render revision tasks
    const revisionContainer = document.getElementById('smart-revision-tasks');
    const revisionGroup = document.getElementById('smart-revision-group');
    if (data.revisionTasks && data.revisionTasks.length > 0) {
      revisionGroup.style.display = 'block';
      revisionContainer.innerHTML = data.revisionTasks.map(task => createSmartTaskHTML(task, 'revision')).join('');
    } else {
      revisionGroup.style.display = 'none';
    }

    // Show empty state if no tasks at all
    const emptyState = document.getElementById('smart-empty-state');
    if (!data.tasks || data.tasks.length === 0) {
      syllabusGroup.style.display = 'none';
      revisionGroup.style.display = 'none';
      emptyState.classList.remove('hidden');
    } else {
      emptyState.classList.add('hidden');
    }

    // Update counts
    document.getElementById('smart-syllabus-count').textContent = data.stats.syllabus || 0;
    document.getElementById('smart-revision-count').textContent = data.stats.revision || 0;
  }

  /**
   * Create HTML for a single smart task card
   */
  function createSmartTaskHTML(task, type) {
    const isCompleted = task.status === 'completed';
    const priorityColors = {
      high:   'border-red-500/30 bg-red-500/5',
      medium: 'border-amber-500/20 bg-amber-500/5',
      low:    'border-gray-500/20 bg-gray-500/5'
    };
    const priorityBadge = {
      high:   'bg-red-500/20 text-red-400',
      medium: 'bg-amber-500/20 text-amber-400',
      low:    'bg-gray-500/20 text-gray-400'
    };
    const typeBadge = type === 'syllabus'
      ? '<span class="px-1.5 py-0.5 rounded text-[10px] font-bold bg-emerald-500/15 text-emerald-400 border border-emerald-500/25">New Topic</span>'
      : '<span class="px-1.5 py-0.5 rounded text-[10px] font-bold bg-amber-500/15 text-amber-400 border border-amber-500/25">Revision</span>';
    const icon = type === 'syllabus' ? '📘' : '🔁';

    return `
      <div class="glass-card p-4 border-l-4 ${priorityColors[task.priority] || ''} flex items-center gap-4 group hover:bg-white/5 transition-all cursor-pointer ${isCompleted ? 'opacity-60' : ''}"
           onclick="toggleSmartTask('${task._id}')" id="smart-task-${task._id}">
        <div class="w-6 h-6 rounded-full border-2 flex items-center justify-center flex-shrink-0 transition-all
          ${isCompleted ? 'bg-purple-500 border-purple-500' : 'border-gray-600 group-hover:border-purple-400'}">
          ${isCompleted ? '<svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>' : ''}
        </div>
        <span class="text-xl flex-shrink-0">${icon}</span>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-0.5">
            <p class="text-sm font-semibold text-white ${isCompleted ? 'line-through' : ''}">${escapeHtml(task.title)}</p>
            ${typeBadge}
          </div>
          <p class="text-xs text-gray-500">${escapeHtml(task.subject)}${task.chapter ? ' · ' + escapeHtml(task.chapter) : ''}</p>
        </div>
        <div class="text-right flex-shrink-0 flex flex-col items-end gap-1">
          <span class="text-xs px-2 py-1 rounded-lg ${priorityBadge[task.priority] || ''}">${task.priority}</span>
          <span class="text-[10px] text-gray-600">${isCompleted ? '✅ Done' : '⏳ Pending'}</span>
        </div>
      </div>
    `;
  }

  /**
   * Update smart plan progress bar and counters
   */
  function updateSmartProgress(stats) {
    const progressBar = document.getElementById('smart-progress-bar');
    const progressText = document.getElementById('smart-progress-text');

    progressBar.style.width = stats.progressPercent + '%';
    progressText.textContent = `${stats.completed} / ${stats.total} tasks`;
  }

  /**
   * Toggle smart task completion status
   */
  async function toggleSmartTask(taskId) {
    const taskEl = document.getElementById('smart-task-' + taskId);
    if (!taskEl) return;

    // Optimistic UI: add a brief pulse
    taskEl.style.transform = 'scale(0.98)';
    setTimeout(() => { taskEl.style.transform = 'scale(1)'; }, 150);

    try {
      const res = await fetch(`/planner/smart-toggle/${taskId}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
      });
      const data = await res.json();

      if (data.error) throw new Error(data.error);

      // Refresh the smart plan view
      const tasksRes = await fetch('/planner/smart-tasks');
      const tasksData = await tasksRes.json();

      if (tasksData.success) {
        renderSmartPlan({
          tasks: tasksData.tasks,
          syllabusTasks: tasksData.syllabusTasks,
          revisionTasks: tasksData.revisionTasks,
          stats: tasksData.stats,
        });
      }
    } catch (e) {
      console.error('Toggle smart task failed:', e);
    }
  }

  /**
   * Escape HTML to prevent XSS in dynamic content
   */
  function escapeHtml(text) {
    if (!text) return '';
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // ════════════════════════════════════════════
  // ── Existing AI Plan Functions (unchanged) ──
  // ════════════════════════════════════════════

  async function generatePlan() {
    const btn = document.getElementById('generate-btn');
    btn.innerHTML = '<div class="w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></div> Generating...';
    btn.disabled = true;

    try {
      const res = await fetch('/planner/generate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
      });
      const data = await res.json();
      if (data.error) throw new Error(data.error);
      location.reload();
    } catch (e) {
      alert('Failed to generate plan: ' + e.message);
      btn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg> AI Plan';
      btn.disabled = false;
    }
  }

  async function toggleTask(index) {
    const taskEl = document.getElementById('task-' + index);
    try {
      const res = await fetch('/planner/toggle', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ taskIndex: index }),
      });
      const data = await res.json();
      if (data.error) throw new Error(data.error);
      location.reload();
    } catch (e) {
      console.error('Toggle failed:', e);
    }
  }

  // ═══════════════════════════════════════
  // ── Auto-load smart tasks on page load ──
  // ═══════════════════════════════════════
  (async function loadExistingSmartTasks() {
    try {
      const res = await fetch('/planner/smart-tasks');
      const data = await res.json();
      if (data.success && data.tasks && data.tasks.length > 0) {
        renderSmartPlan({
          tasks: data.tasks,
          syllabusTasks: data.syllabusTasks,
          revisionTasks: data.revisionTasks,
          stats: data.stats,
        });
      }
    } catch (e) {
      // Silent fail — don't block page load
      console.error('Failed to load smart tasks:', e);
    }
  })();
</script>

<%- include('partials/footer') %>
